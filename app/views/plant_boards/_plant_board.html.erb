<div class="p-4 md:w-1/3">
  <div class="h-full flex flex-col border-2 border-gray-200 border-opacity-60 rounded-lg overflow-hidden">
    <%= image_tag plant_board.plant_board_image_url, class:"lg:h-72 md:h-72 w-full object-cover object-center" %>

    <div class="p-6 flex flex-col flex-1">
      <h2 class="tracking-widest text-xs title-font font-medium text-gray-400 mb-1">CATEGORY</h2>

      <h1>
        <%= link_to plant_board.plant_name, plant_board_path(plant_board), class:"title-font text-lg font-medium text-gray-900 mb-5" %>
      </h1>

      <%= link_to plant_board.body, '#', class:"mb-10 line-clamp-3" %>

      <% remaining_days = plant_board.watering_remaining_days %>

        <div class="mb-6 text-sm text-gray-600">
          <p>水やり頻度：<%= plant_board.watering_interval_days %>日ごと</p>

          <% if remaining_days.nil? %>
            <p>水やり情報が未設定です</p>
          <% elsif remaining_days > 0 %>
            <p>水やりまであと<%= remaining_days %>日</p>
          <% elsif remaining_days == 0 %>
            <p>今日水やりです</p>
          <% else %>
            <p>水やり予定日を<%= remaining_days.abs %>日過ぎています</p>
          <% end %>
        </div>

        <div class="mb-3">
        <%= link_to "水やり完了", water_plant_board_path(plant_board),class:"w-full py-3 px-0 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg bg-primary border border-primary-line text-primary-foreground hover:bg-primary-hover focus:outline-hidden focus:bg-primary-hover disabled:opacity-50 disabled:pointer-events-none", data:{ turbo_method: :patch } %>
        </div>

      <div class="flex items-center justify-end mt-auto">
        <div class="text-gray-400 mr-3 inline-flex items-center leading-none text-sm pr-3 py-1 border-r-2 border-gray-200">
          <%= link_to "編集", edit_plant_board_path(plant_board), class:"w-4 h-4 mr-1" %>
        </div>

        <div class="text-gray-400 inline-flex items-center leading-none text-sm">
          <%= link_to "削除", plant_board_path(plant_board), class:"w-4 h-4 mr-1", data:{turbo_method: :delete} %>
        </div>
      </div>
    </div>
  </div>
</div>
