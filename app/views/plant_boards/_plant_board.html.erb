<div class="p-4 md:w-1/3">
  <div class="h-full flex flex-col border-2 border-gray-200 border-opacity-60 rounded-lg overflow-hidden">
    <%= image_tag plant_board.plant_board_image_url, class: "lg:h-72 md:h-72 w-full object-cover object-center" %>

    <div class="p-6 flex flex-col flex-1">
      <div class="flex items-center justify-between mb-1">
        <h2 class="tracking-widest text-xs title-font font-medium text-gray-400">
          CATEGORY
        </h2>

        <div class="flex items-center gap-3 text-gray-400">
          <%= link_to edit_plant_board_path(plant_board),
              class: "hover:text-gray-600",
              title: "編集",
              aria: { label: "編集" } do %>

            <svg xmlns="http://www.w3.org/2000/svg"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke-width="1.5"
                 stroke="currentColor"
                 class="w-5 h-5">
              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
            </svg>
          <% end %>

          <%= link_to plant_board_path(plant_board),
              class: "hover:text-red-500",
              title: "削除",
              aria: { label: "削除" },
              data: {
                turbo_method: :delete,
                turbo_confirm: "削除しますか？"
              } do %>

            <svg xmlns="http://www.w3.org/2000/svg"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke-width="1.5"
                 stroke="currentColor"
                 class="w-5 h-5">
              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673A2.25 2.25 0 0 1 15.916 21H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
          <% end %>
        </div>
      </div>

      <h1>
        <%= link_to plant_board.plant_name,
            plant_board_path(plant_board),
            class: "title-font text-lg font-medium text-gray-900 mb-5" %>
      </h1>

      <%= link_to plant_board.body, "#", class: "mb-10 line-clamp-3" %>

      <% remaining_days = plant_board.watering_remaining_days %>

      <div class="mb-6 text-sm text-gray-600">
        <p>水やり頻度：<%= plant_board.watering_interval_days %>日ごと</p>

        <% if remaining_days.nil? %>
          <p>水やり情報が未設定です</p>
        <% elsif remaining_days > 0 %>
          <p>水やりまであと<%= remaining_days %>日</p>
        <% elsif remaining_days == 0 %>
          <p>今日水やりです</p>
        <% else %>
          <p>水やり予定日を<%= remaining_days.abs %>日過ぎています</p>
        <% end %>
      </div>
      <div class="mt-auto">
        <%= link_to "水やり完了",
            water_plant_board_path(plant_board),
            class: "inline-flex w-full items-center justify-center gap-x-2 rounded-lg border border-sky-300 bg-sky-50 px-0 py-3 text-sm font-medium text-sky-700 hover:bg-sky-100 focus:outline-hidden focus:bg-sky-100 disabled:pointer-events-none disabled:opacity-50",
            data: { turbo_method: :patch } %>
      </div>
    </div>
  </div>
</div>
