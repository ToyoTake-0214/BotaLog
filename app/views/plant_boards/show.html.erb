<% content_for(:title, t('.title')) %>
<div class="bg-white py-6 sm:py-8 lg:py-12">
  <div class="mx-auto max-w-screen-xl px-4 md:px-8">

    <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between md:mb-16">
      <div>
        <h2 class="mb-2 text-2xl font-bold text-gray-800 lg:text-3xl">
          育成記録
        </h2>

        <p class="text-gray-500 md:text-lg">
          写真とメモで植物の成長を記録しましょう
        </p>
      </div>

      <%= link_to new_plant_board_plant_path(@plant_board),
                  class: "inline-flex items-center justify-center rounded-lg border border-green-600 px-4 py-3 text-sm font-medium text-green-700 hover:bg-green-50 sm:mt-1" do %>
        ＋ 記録を追加
      <% end %>
    </div>

    <div class="container px-5 py-5 mx-auto">
      <div class="flex flex-wrap -m-4">
        <% if @plants.present? %>
          <%= render @plants %>
        <% else %>
          <div class="w-full rounded-lg border border-dashed border-gray-300 bg-white px-6 py-10 text-center">
            <p class="mb-4 text-gray-500">
              育成記録がありません
            </p>

            <%= link_to new_plant_board_plant_path(@plant_board),
                        class: "inline-flex items-center justify-center rounded-lg bg-green-600 px-4 py-3 text-sm font-medium text-white hover:bg-green-700" do %>
              最初の記録を追加する
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
