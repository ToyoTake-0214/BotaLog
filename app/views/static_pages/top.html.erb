<section class="py-20">
  <div class="container items-center max-w-6xl px-4 mx-auto sm:px-20 md:px-32 lg:px-16">
    <div class="flex flex-wrap items-center -mx-3">
      <div class="order-1 w-full px-3 lg:w-1/2 lg:order-0">
        <div class="w-full lg:max-w-md">
          <h2 class="mb-4 text-3xl font-bold leading-tight tracking-tight text-gray-900 sm:text-4xl font-heading">
            日々の生活に植物を添えて
          </h2>

          <p class="mb-6 font-medium tracking-tight text-gray-500 xl:mb-8">
            植物の水やり頻度や育成記録を、写真とメモで気軽に管理できます。
          </p>
          <% if logged_in? %>
            <%= link_to "マイ植物を見る",
                        plant_boards_path,
                        class: "inline-flex items-center justify-center rounded-full bg-green-600 px-8 py-4 text-base font-medium leading-6 text-white hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2" %>
          <% else %>
            <%= link_to "新規登録",
                        new_user_path,
                        class: "inline-flex items-center justify-center rounded-full bg-green-600 px-8 py-4 text-base font-medium leading-6 text-white hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2" %>

            <p class="mt-3 text-sm text-gray-500">
              メールアドレス不要。ユーザー名とパスワードだけで始められます。
            </p>
          <% end %>
        </div>
      </div>

      <div class="order-0 w-full px-3 mb-12 lg:w-1/2 lg:order-1 lg:mb-0">
        <%= image_tag "top_image.png",
                      class: "mx-auto sm:max-w-sm lg:max-w-full",
                      alt: "植物のある暮らし" %>
      </div>
    </div>
  </div>
</section>
